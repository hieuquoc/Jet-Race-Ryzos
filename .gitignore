# Unity generated
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
UserSettings/
MemoryCaptures/

# Asset meta data should be tracked
!/[Aa]ssets/**/*.meta

# Autogenerated VS/JetBrains files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Visual Studio cache/options directory
.vs/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Builds
*.apk
*.aab
*.xcodeproj
*.xcworkspace
*.xcuserdata/
*.ipa

# Crash Reports
CrashReports/

# Unity addressesables
Assets/AddressableAssetsData/*.bin
Assets/AddressableAssetsData/*.settings

# Crashlytics
crashlytics-build.properties

# Memory capturer
*.mem

# Packed assets
*.unitypackage

# Logs
Logs/

# Lock files
PackageLock.json
packages-lock.json

# Prevent checking in local plugin files
Assets/Plugins/**/obj/

# Ignore built player data
*.apk
*.exe
*.app
*.x86
*.x86_64
*.so

# Keep the project settings tracked except local overrides
ProjectSettings/ProjectSettings.asset
ProjectSettings/TagManager.asset
ProjectSettings/GraphicsSettings.asset
# ignore other large generated settings
ProjectSettings/EditorBuildSettings.asset

# End of file
